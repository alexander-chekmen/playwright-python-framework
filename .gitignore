# =========================
# Python Environment
# =========================
.venv/              # Virtual environment (local Python dependencies)
__pycache__/       # Compiled Python bytecode (auto-generated)
*.py[cod]           # Compiled Python files
*$py.class          # JVM-like Python artifacts (rare, but safe to ignore)

# =========================
# PyCharm / IDE
# =========================
.idea/              # PyCharm project settings (machine-specific)
*.iml               # JetBrains module configuration files

# =========================
# Environment Variables
# =========================
.env                # Local secrets (URLs, credentials, API keys)

# =========================
# Pytest
# =========================
.pytest_cache/      # Cache for test discovery and execution speedup

# =========================
# Playwright Artifacts
# =========================
playwright-report/  # HTML test reports generated by Playwright
test-results/       # Temporary test execution results
screenshots/        # Failure or debug screenshots (runtime artifacts)
videos/             # Video recordings of test runs
traces/             # Playwright trace files (debugging sessions)

# =========================
# OS Files
# =========================
.DS_Store           # macOS folder metadata (Finder settings)
